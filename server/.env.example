# Database path (SQLite file). Create dir if needed.
DATABASE_PATH=./data/homework.db

# Session secret (use a long random string in production)
SESSION_SECRET=change-me-in-production

# Set to true only behind HTTPS (reverse proxy). Leave unset/false for http:// single-port (e.g. localhost:3001)
# SESSION_COOKIE_SECURE=true

# HTTP port — dev, PM2, and `pnpm start` all use this one port (API + UI + Socket.IO). Example PM2: 3001
PORT=3000

# Bind address (default 0.0.0.0 so LAN / public firewall rules can reach this PORT)
# LISTEN_HOST=127.0.0.1

# Local dev — Vite runs inside Express on PORT above (not a separate 5173 server)
NODE_ENV=development

# Optional strict CORS/Socket.IO allowlist (comma-separated). Leave unset for single-host PM2 on PORT
# (server reflects the browser Origin). Set when you want to lock origins, e.g.:
# FRONTEND_ORIGIN=https://app.example.com,https://www.app.example.com

# Comma-separated emails that become platform admin + parent on server start (must already be registered)
# ADMIN_EMAILS=you@example.com
