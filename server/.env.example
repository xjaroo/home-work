# Database path (SQLite file). Create dir if needed.
DATABASE_PATH=./data/homework.db

# Session secret (use a long random string in production)
SESSION_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=development

# Frontend origin(s) for CORS. Production: comma-separated (e.g. http://localhost:5173,https://app.example.com).
# In development, any origin is allowed so you can use http://YOUR_IP:5173 on the same WiFi.
# FRONTEND_ORIGIN=http://localhost:5173

# Comma-separated emails that become platform admin + parent on server start (must already be registered)
# ADMIN_EMAILS=you@example.com
